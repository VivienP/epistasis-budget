#!/usr/bin/env bash
# epibudget pre-commit gate. Opt in with:  git config core.hooksPath scripts/hooks
#
# Source/test/script changes run format, lint, types, and the offline tests. Documentation-only changes
# retain the artifact and secret gates without paying for unrelated source checks. A missing tool blocks
# source/test/script commits and is tolerated only when no executable project code is staged.
set -uo pipefail

fail=0
have() { command -v "$1" >/dev/null 2>&1; }
source_staged=""
if have git; then
  source_staged=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^(src|tests|scripts)/' || true)
fi

run() {  # run <label> <cmd...>; block on failure or on a missing source-commit tool
  local label="$1"; shift
  if ! have "$1"; then
    if [ -n "$source_staged" ]; then
      echo "  [FAIL] $label: required tool missing for source commit ($1)"
      fail=1
    else
      echo "  [skip] $label ($1 not installed; no source/test/script file staged)"
    fi
    return 0
  fi
  echo "  [run ] $label"
  if ! "$@"; then echo "  [FAIL] $label"; fail=1; fi
}

echo "epibudget pre-commit:"

# Forbidden-file gate: these must never be committed (git-commit-rules section 2).
# .gitignore is the first line of defense; this blocks a `git add -f` or an already-tracked slip.
if have git; then
  forbidden=$(git diff --cached --name-only | grep -iE '(^|/)(CLAUDE\.md|AGENTS\.md|ROADMAP\.md|AI_CONTRACT\.md|\.env($|\.)|.*\.pem$|.*\.key$)|(^|/)\.(claude|agents|codex)/' || true)
  if [ -n "$forbidden" ]; then
    echo "  [FAIL] forbidden file(s) staged:"; echo "$forbidden" | sed 's/^/    - /'
    echo "         these are excluded by git-commit-rules; unstage with: git restore --staged <file>"
    fail=1
  fi
fi

if [ -n "$source_staged" ]; then
  run "ruff format --check" ruff format --check src/ tests/ scripts/
  run "ruff check"          ruff check src/ tests/ scripts/
  run "mypy --strict"       mypy --strict src/
  run "pytest (offline)"    pytest -q -m "not slow and not data"
else
  echo "  [skip] source quality checks (no source/test/script file staged)"
fi
run "artifact claims"     python scripts/validate_artifacts.py

# Secret scan on staged content (best-effort; blocks on a likely key). The hook scripts are excluded
# from their own scan — their detection-pattern literals (sk-…, hf_…, BEGIN PRIVATE KEY) would
# otherwise self-trigger a false positive whenever the hook itself is staged.
if have git; then
  if git diff --cached -U0 -- . ':(exclude)scripts/hooks/*' | grep -nE '(sk-[A-Za-z0-9]{20,}|ANTHROPIC_API_KEY=|hf_[A-Za-z0-9]{20,}|-----BEGIN [A-Z ]*PRIVATE KEY-----)'; then
    echo "  [FAIL] possible secret in staged diff"; fail=1
  fi
fi

if [ "$fail" -ne 0 ]; then
  echo "pre-commit: BLOCKED. Fix the failures above (or --no-verify only with Vivien's explicit approval)."
  exit 1
fi
echo "pre-commit: OK"
